# Port Digital Twin - Development Environment
# Copy to .env and fill with your values

# Backend
PORT=5001
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017
JWT_SECRET=dev-secret-key-minimum-32-characters
FRONTEND_URL=http://localhost:3000

# Python services (local URLs)
DC_POWER_FLOW_API=http://localhost:5002
VESSEL_API=http://localhost:5003
VESSEL_API_URL=http://localhost:5003
PV_MODEL_API=http://localhost:5004

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=port_digital_twin
POSTGRES_USER=portadmin
POSTGRES_PASSWORD=portpass123

# Email (optional for dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Frontend
NEXT_PUBLIC_BACKEND_URL=http://localhost:5001
